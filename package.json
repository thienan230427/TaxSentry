{
  "name": "taxsentry",
  "version": "1.0.4",
  "type": "module",
  "description": "TaxSentry is a provider-first local AI agent with a friendly setup wizard, persistent memory, and cross-platform TUI.",
  "bin": {
    "taxsentry": "bin/taxsentry.js",
    "ts": "bin/taxsentry.js"
  },
  "scripts": {
    "start": "node bin/taxsentry.js start",
    "dev": "node bin/taxsentry.js start",
    "test": "node tests/privacy_runtime_regressions.mjs && node tests/update_command_regressions.mjs && node tests/package_smoke.mjs",
    "pack:smoke": "node tests/package_smoke.mjs",
    "prepack": "npm run pack:smoke",
    "prepublishOnly": "npm run test && npm run lint",
    "lint": "eslint src bin tests"
  },
  "keywords": [
    "ai-agent",
    "lmstudio",
    "codex",
    "provider",
    "memory",
    "tui",
    "openai-compatible"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thienan230427/TaxSentry.git"
  },
  "dependencies": {
    "boxen": "^7.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "figlet": "^1.7.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0",
    "which": "^4.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=24"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "files": [
    "bin/",
    "src/",
    "taxsentry-core/.env.example",
    "taxsentry-core/pyproject.toml",
    "taxsentry-core/requirements.txt",
    "taxsentry-core/scripts/create_mock_report.py",
    "taxsentry-core/src/taxsentry/**/*.py",
    "taxsentry-core/src/taxsentry/knowledge_base/*.md",
    "taxsentry-core/tests/test_excel_parser_regressions.py",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
