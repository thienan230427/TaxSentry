# Never publish local secrets or runtime state
.env
.env.*
!.env.example
*.db
*.sqlite
*.sqlite3
*.pid

# Package-level build/runtime junk
node_modules/
coverage/
dist/
.vscode/

# TaxSentry core local state and generated artifacts
taxsentry-core/.env
taxsentry-core/.env.*
!taxsentry-core/.env.example
taxsentry-core/*.db
taxsentry-core/*.sqlite
taxsentry-core/*.sqlite3
taxsentry-core/.processed_ids.json
taxsentry-core/parsed_report.json
taxsentry-core/audit_report.md
taxsentry-core/downloads/
taxsentry-core/scratch/

# Python caches and packaging leftovers
taxsentry-core/**/__pycache__/
taxsentry-core/**/*.py[cod]
taxsentry-core/**/*.pyo
taxsentry-core/**/*.pyd
taxsentry-core/**/*.so
taxsentry-core/**/*.egg-info/

# Local backups and temp files
taxsentry-core/.env.dev.bak
taxsentry-core/.env.old.backup
taxsentry-core/**/*.log
taxsentry-core/**/*.tmp
taxsentry-core/**/*.bak
