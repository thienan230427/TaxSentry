# --- CẤU HÌNH BẢO MẬT EMAIL TAXSENTRY ---
# Sao chép tệp này thành .env và điền thông tin thực tế của Sếp nha~! (◕‿◕✿)

# Địa chỉ máy chủ IMAP (Mặc định cho Gmail)
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993

# Tài khoản email nhận báo cáo (Tài khoản của Giám đốc hoặc của Sếp)
EMAIL_USER=an25800600029@hutech.edu.vn

# Mật khẩu ứng dụng (App Password) - KHÔNG PHẢI mật khẩu email chính thức nha Sếp!
# Hướng dẫn lấy App Password của Gmail: Cài đặt Google Account -> Bảo mật -> Xác minh 2 bước -> Mật khẩu ứng dụng.
EMAIL_PASS=your_app_password_here

# Địa chỉ email của Kế toán trưởng (Chỉ chấp nhận báo cáo từ địa chỉ này để bảo mật!)
ACCOUNTANT_EMAIL=bao25800600042@hutech.edu.vn
